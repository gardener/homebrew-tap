{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":semanticCommitsDisabled",
    "customManagers:githubActionsVersions",
  ],
  labels: [
    "kind/enhancement",
    "renovate",
  ],
  minimumReleaseAge: "3 days",
  schedule: [
    "on the first day of the month",
  ],
  packageRules: [
    {
      groupName: "github-actions",
      matchManagers: [
        "github-actions",
      ],
    },
  ],
}
